# Copy to .env and fill in a real key, or export these in your shell.
# Pick ONE backend by providing its key (OpenAI is the default if its key is set).

# OpenAI GPT-4o vision  (default backend)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude vision  (alternative)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional overrides
# BACKEND=openai            # openai | claude | ollama
OPENAI_MODEL=gpt-4o-mini       # gpt-4o (best) | gpt-4o-mini (cheapest)
# OPENAI_DETAIL=high        # high | low  (low is cheaper, weaker on small text)
# CLAUDE_MODEL=claude-sonnet-4-6
# OLLAMA_MODEL=llava
# OUTPUT_XLSX=output_results.xlsx
